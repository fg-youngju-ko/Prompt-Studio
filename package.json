{
  "name": "prompt-studio",
  "displayName": "Prompt Studio",
  "description": "Claude Code와 함께 바이브 코딩할 때, 고품질 프롬프트를 쉽고 빠르게 생성하는 도구",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptStudio.startProject",
        "title": "Prompt Studio: 프로젝트 시작 프롬프트 생성"
      },
      {
        "command": "promptStudio.startFromIdea",
        "title": "Prompt Studio: 아이디어로 시작하기"
      },
      {
        "command": "promptStudio.buildFeaturePrompt",
        "title": "Prompt Studio: 기능 구현 프롬프트 생성"
      },
      {
        "command": "promptStudio.buildBugFixPrompt",
        "title": "Prompt Studio: 버그 수정 프롬프트 생성"
      },
      {
        "command": "promptStudio.buildRefactorPrompt",
        "title": "Prompt Studio: 리팩토링 프롬프트 생성"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "mocha": "^11.7.6",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.5"
  }
}
